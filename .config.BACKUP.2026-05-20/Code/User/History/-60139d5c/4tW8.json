{
  "workbench.colorTheme": "GitHub Dark Colorblind (Beta)",
  "workbench.activityBar.location": "top",
  "window.commandCenter": false,
  "workbench.browser.showInTitleBar": true,
  "editor.fontFamily": "'Caskaydia Cove Nerd font Mono SemiBold' , monospace,",
  "workbench.iconTheme": "material-icon-theme",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "terminal.integrated.fontLigatures.enabled": true,
  "editor.fontLigatures": true,
  "terminal.integrated.fontLigatures.featureSettings": "\"calt\" on, \"liga\" on,",
  "[javascript]": {
    "editor.maxTokenizationLineLength": 2500,
  },
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
  ],
  "editor.minimap.enabled": false,
  "workbench.settings.showAISearchToggle": false,
  "editor.guides.bracketPairs": "active",
  "chat.mcp.apps.enabled": false,
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "editor.tabSize": 2,
  "chat.disableAIFeatures": true,
  "extensions.autoUpdate": false,
  "chat.editor.fontSize": 14,
  "debug.console.fontSize": 14,
  "markdown.preview.fontSize": 16,
  "editor.fontSize": 16,
  "terminal.integrated.fontSize": 14,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "off",
  },
}
